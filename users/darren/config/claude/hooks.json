{
  "hooks": [
    {
      "event": "SessionStart",
      "matcher": {},
      "action": {
        "type": "command",
        "command": "echo '{\"systemMessage\": \"Branch: '$(git branch --show-current 2>/dev/null || echo none)' | Last commit: '$(git log --oneline -1 2>/dev/null || echo none)'\"}'"
      }
    },
    {
      "event": "SessionStart",
      "matcher": {
        "inputContains": "compact"
      },
      "action": {
        "type": "command",
        "command": "echo '{\"systemMessage\": \"Post-compaction reminder: Check task list for in-progress work. Re-read any files you were actively editing. Current branch: '$(git branch --show-current 2>/dev/null || echo none)'\"}'"
      }
    },
    {
      "event": "PreCompact",
      "matcher": {},
      "action": {
        "type": "command",
        "command": "echo '{\"systemMessage\": \"About to compact. Save any critical in-progress context or task state now — compaction will replace this conversation history.\"}'"
      }
    },
    {
      "event": "Notification",
      "matcher": {},
      "action": {
        "type": "command",
        "command": "osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code\"' 2>/dev/null || true"
      }
    },
    {
      "event": "PostToolUse",
      "if": "Edit(*.nix)|Write(*.nix)",
      "action": {
        "type": "command",
        "command": "alejandra --quiet \"$CC_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
      }
    },
    {
      "event": "PostToolUse",
      "if": "Edit(*.rs)|Write(*.rs)",
      "action": {
        "type": "command",
        "command": "rustfmt \"$CC_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
      }
    },
    {
      "event": "PostToolUse",
      "if": "Edit(*.ts)|Write(*.ts)|Edit(*.tsx)|Write(*.tsx)|Edit(*.js)|Write(*.js)|Edit(*.jsx)|Write(*.jsx)|Edit(*.css)|Write(*.css)|Edit(*.html)|Write(*.html)|Edit(*.json)|Write(*.json)",
      "action": {
        "type": "command",
        "command": "prettier --write \"$CC_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
      }
    },
    {
      "event": "PostToolUse",
      "if": "Edit(*.dart)|Write(*.dart)",
      "action": {
        "type": "command",
        "command": "dart format \"$CC_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
      }
    },
    {
      "event": "PostToolUse",
      "if": "Edit(*.lua)|Write(*.lua)",
      "action": {
        "type": "command",
        "command": "stylua \"$CC_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
      }
    },
    {
      "event": "PostToolUse",
      "if": "Edit(*.py)|Write(*.py)",
      "action": {
        "type": "command",
        "command": "ruff format \"$CC_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
      }
    },
    {
      "event": "Stop",
      "matcher": {},
      "action": {
        "type": "command",
        "command": "~/.claude/scripts/quality-gate.sh"
      }
    }
  ]
}
