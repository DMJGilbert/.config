{
  "hooks": [
    {
      "event": "SessionStart",
      "matcher": {},
      "action": {
        "type": "command",
        "command": "echo '{\"systemMessage\": \"Branch: '$(git branch --show-current 2>/dev/null || echo none)' | Last commit: '$(git log --oneline -1 2>/dev/null || echo none)'\"}'"
      }
    },
    {
      "event": "PostToolUse",
      "matcher": {
        "tool": "Write",
        "inputContains": ".nix"
      },
      "action": {
        "type": "command",
        "command": "alejandra --quiet \"$CC_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
      }
    },
    {
      "event": "PostToolUse",
      "matcher": {
        "tool": "Edit",
        "inputContains": ".nix"
      },
      "action": {
        "type": "command",
        "command": "alejandra --quiet \"$CC_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
      }
    },
    {
      "event": "PostToolUse",
      "matcher": {
        "tool": "Write",
        "inputContains": ".rs"
      },
      "action": {
        "type": "command",
        "command": "rustfmt \"$CC_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
      }
